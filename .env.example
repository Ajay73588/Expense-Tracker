# Database - SQLite for zero-config local development
DATABASE_URL="file:./dev.db"

# AI provider (optional - falls back to rule-based simulated responses)
# MINIMAX_API_KEY=""
# MINIMAX_API_URL="https://api.minimax.chat/v1/text/chatcompletion_v2"

# Auth (optional - system uses a demo user in dev mode)
# CLERK_SECRET_KEY=""
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""

# Redis (optional - falls back to in-memory cache)
# REDIS_URL=""

# ─── Firebase (Firestore migration) ─────────────────────────────────────────
# Set USE_FIREBASE=true to route DB calls through Firestore instead of Prisma.
# Leave false (or unset) to keep using Prisma — safe rollback path.
USE_FIREBASE=false

# Firebase Admin SDK credentials (from your Firebase project service account)
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
